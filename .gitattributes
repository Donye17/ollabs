# Normalize all text files to LF in the repo, regardless of OS.
# Prevents the whole-tree CRLF/LF phantom diffs.
* text=auto eol=lf

# Binary assets — never touch these.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
